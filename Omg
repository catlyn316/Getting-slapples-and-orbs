local function goToTeleport1()
    for _, v in ipairs(workspace:GetDescendants()) do
        if nameCI(v.Name, "teleport1") and v:IsA("BasePart") then
            teleportTo(v.CFrame); print("[OrbScript] 已傳送到 teleport1"); return
        end
    end
    warn("[OrbScript] 找不到 teleport1，跳過")
end

local function handleGloves()
    if GLOVE_TELEPORT ~= 1 then return end
    local arena = workspace:FindFirstChild("Arena")
    if not arena then return end
    local island5 = arena:FindFirstChild("island5")
    if not island5 then return end
    local slapples = island5:FindFirstChild("Slapples")
    if not slapples then return end
    local root = getRootPart()
    if not root then return end
    local count = 0
    for _, slapple in ipairs(slapples:GetChildren()) do
        local glove = slapple:FindFirstChild("Glove")
        if glove then
            if glove:IsA("Model") and glove.PrimaryPart then
                glove:SetPrimaryPartCFrame(root.CFrame); count = count + 1
            elseif glove:IsA("BasePart") then
                glove.CFrame = root.CFrame; count = count + 1
            end
        end
    end
    print(string.format("[OrbScript] 傳送 %d 個 Glove", count))
end

