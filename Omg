-- ── 跳服：少人模式（升序第 8～50 台）──
local function joinSmallestServer()
    if switchServerPending then return end
    switchServerPending = true
    cleanVisited()
    print("[OrbScript] 開始跳服（少人模式：第8~50）...")
    local pid = game.PlaceId
    local success = pcall(function()
        local response = HttpService:JSONDecode(
            game:HttpGet("https://games.roblox.com/v1/games/" .. pid .. "/servers/Public?sortOrder=Asc&limit=100")
        )
        if response.data and #response.data > 0 then
            table.sort(response.data, function(a, b) return a.playing < b.playing end)
            local valid = {}
            for _, s in ipairs(response.data) do
                if s.id ~= game.JobId
                and not isRecentlyVisited(s.id)
                and s.playing < s.maxPlayers then
                    table.insert(valid, s)
                end
            end
            local pool = {}
            for i = 8, math.min(50, #valid) do
                table.insert(pool, valid[i])
            end
            if #pool == 0 then
                for i = math.max(1, #valid - 2), #valid do
                    table.insert(pool, valid[i])
                end
            end
            if #pool == 0 then
                print("[OrbScript] 前50服全滿或已訪問，改隨機跳")
                TeleportService:Teleport(pid, LocalPlayer)
                return
            end
            local targetServer = pool[math.random(1, #pool)]
            if targetServer and targetServer.id then
                markVisited(targetServer.id)
                print(string.format("[OrbScript] 跳往伺服器（%d/%d人）", targetServer.playing, targetServer.maxPlayers))
                TeleportService:TeleportToPlaceInstance(pid, targetServer.id)
            else
                TeleportService:Teleport(pid, LocalPlayer)
            end
        else
            TeleportService:Teleport(pid, LocalPlayer)
        end
    end)
    if not success then TeleportService:Teleport(pid, LocalPlayer) end
end

-- ── 跳服：多人模式（降序不含額滿，第 20～50 台）──
local function joinMostPlayedServer()
    if switchServerPending then return end
    switchServerPending = true
    cleanVisited()
    local pid = game.PlaceId
    local success = pcall(function()
        local response = HttpService:JSONDecode(
            game:HttpGet("https://games.roblox.com/v1/games/" .. pid .. "/servers/Public?sortOrder=Asc&limit=100")
        )
        if response.data and #response.data > 0 then
            local valid = {}
            for _, s in ipairs(response.data) do
                if s.id ~= game.JobId
                and not isRecentlyVisited(s.id)
                and s.playing < s.maxPlayers then
                    table.insert(valid, s)
                end
            end
            table.sort(valid, function(a, b) return a.playing > b.playing end)
            local pool = {}
            for i = 20, math.min(50, #valid) do
                table.insert(pool, valid[i])
            end
            if #pool == 0 then
                pool = valid
            end
            if #pool == 0 then
                print("[OrbScript] 無可用伺服器，改隨機跳")
                TeleportService:Teleport(pid, LocalPlayer)
                return
            end
            local targetServer = pool[math.random(1, #pool)]
            if targetServer and targetServer.id then
                markVisited(targetServer.id)
                print(string.format("[OrbScript] 跳往伺服器（%d/%d人）", targetServer.playing, targetServer.maxPlayers))
                TeleportService:TeleportToPlaceInstance(pid, targetServer.id)
            else
                TeleportService:Teleport(pid, LocalPlayer)
            end
        else
            TeleportService:Teleport(pid, LocalPlayer)
        end
    end)
    if not success then TeleportService:Teleport(pid, LocalPlayer) end
end

function hopServer()
    if SERVER_HOP_MODE == 1 then joinSmallestServer()
    elseif SERVER_HOP_MODE == 2 then joinMostPlayedServer()
    else
        if switchServerPending then return end
        switchServerPending = true
        cleanVisited()
        local pid = game.PlaceId
        local success = pcall(function()
            local response = HttpService:JSONDecode(
                game:HttpGet("https://games.roblox.com/v1/games/" .. pid .. "/servers/Public?sortOrder=Asc&limit=100")
            )
            if response.data and #response.data > 0 then
                local valid = {}
                for _, s in ipairs(response.data) do
                    if s.id ~= game.JobId
                    and not isRecentlyVisited(s.id)
                    and s.playing < s.maxPlayers then
                        table.insert(valid, s)
                    end
                end
                if #valid > 0 then
                    local pick = valid[math.random(1, #valid)]
                    markVisited(pick.id)
                    print(string.format("[OrbScript] 跳往伺服器（%d/%d人）", pick.playing, pick.maxPlayers))
                    TeleportService:TeleportToPlaceInstance(pid, pick.id)
                    return
                end
            end
            TeleportService:Teleport(pid, LocalPlayer)
        end)
        if not success then TeleportService:Teleport(pid, LocalPlayer) end
    end
end

local function goToTeleport1()
    for _, v in ipairs(workspace:GetDescendants()) do
        if nameCI(v.Name, "teleport1") and v:IsA("BasePart") then
            teleportTo(v.CFrame); print("[OrbScript] 已傳送到 teleport1"); return
        end
    end
    warn("[OrbScript] 找不到 teleport1，跳過")
end

local function handleGloves()
    if GLOVE_TELEPORT ~= 1 then return end
    local arena = workspace:FindFirstChild("Arena")
    if not arena then return end
    local island5 = arena:FindFirstChild("island5")
    if not island5 then return end
    local slapples = island5:FindFirstChild("Slapples")
    if not slapples then return end
    local root = getRootPart()
    if not root then return end
    local count = 0
    for _, slapple in ipairs(slapples:GetChildren()) do
        local glove = slapple:FindFirstChild("Glove")
        if glove then
            if glove:IsA("Model") and glove.PrimaryPart then
                glove:SetPrimaryPartCFrame(root.CFrame); count = count + 1
            elseif glove:IsA("BasePart") then
                glove.CFrame = root.CFrame; count = count + 1
            end
        end
    end
    print(string.format("[OrbScript] 傳送 %d 個 Glove", count))
end

local tasksDone = {
    glove          = (GLOVE_TELEPORT == 0),
    jetOrb         = (JET_ORB_MODE == 0),
    phaseOrb       = (PHASE_ORB_MODE == 0),
    siphonOrb      = (SIPHON_ORB_MODE == 0),
    materializeOrb = (MATERIALIZE_ORB_MODE == 0),
}

local handledOrbs = {}
local function findOrb(name)
    for _, v in ipairs(workspace:GetDescendants()) do
        if nameCI(v.Name, name) and v:IsA("BasePart") then return v end
    end
    return nil
end

function checkAndHop()
    if JET_ORB_MODE == 1 and not tasksDone.jetOrb and not findOrb("JetOrb") then
        print("[OrbScript] 場上無 JetOrb，視為完成")
        tasksDone.jetOrb = true
    end
    if PHASE_ORB_MODE == 1 and not tasksDone.phaseOrb and not findOrb("PhaseOrb") then
        print("[OrbScript] 場上無 PhaseOrb，視為完成")
        tasksDone.phaseOrb = true
    end
    if SIPHON_ORB_MODE == 1 and not tasksDone.siphonOrb and not findOrb("SiphonOrb") then
        print("[OrbScript] 場上無 SiphonOrb，視為完成")
        tasksDone.siphonOrb = true
    end
    if MATERIALIZE_ORB_MODE == 1 and not tasksDone.materializeOrb and not findOrb("MATERIALIZEOrb") then
        print("[OrbScript] 場上無 MATERIALIZEOrb，視為完成")
        tasksDone.materializeOrb = true
    end

    for key, done in pairs(tasksDone) do
        if not done then
            print(string.format("[OrbScript] 等待任務：%s", key))
            return
        end
    end

    print("[OrbScript] 所有任務完成，跳服")
    hopServer()
end

local function handleOrb(orbName, mode, onFound)
    if mode == 0 then return end
    local orb = findOrb(orbName)
    if orb and not handledOrbs[orb] then
        handledOrbs[orb] = true
        onFound(orb)
        orb.AncestryChanged:Connect(function(_, p)
            if p == nil then
                handledOrbs[orb] = nil
            end
        end)
    end
end

local function anyOrbPresent()
    if JET_ORB_MODE ~= 0 and findOrb("JetOrb") then return true end
    if PHASE_ORB_MODE ~= 0 and findOrb("PhaseOrb") then return true end
    if SIPHON_ORB_MODE == 1 and findOrb("SiphonOrb") then return true end
    if MATERIALIZE_ORB_MODE == 1 and findOrb("MATERIALIZEOrb") then return true end
    return false
end

RunService.Heartbeat:Connect(function()
    if not orbDetectionEnabled then return end

    -- JetOrb
    if JET_ORB_MODE ~= 0 then
        handleOrb("JetOrb", JET_ORB_MODE, function(orb)
            if JET_ORB_MODE == 1 then
                teleportAndTouch(orb)
                tasksDone.jetOrb = true
                checkAndHop()
            else
                if isErrorGlove() then
                    errorGlitchOrb(orb)
                    tasksDone.jetOrb = true
                    checkAndHop()
                else
                    showSwBtn(orb.CFrame, "JetOrb", orb)
                end
            end
        end)
    end

    -- PhaseOrb
    if PHASE_ORB_MODE ~= 0 then
        handleOrb("PhaseOrb", PHASE_ORB_MODE, function(orb)
            if PHASE_ORB_MODE == 1 then
                teleportAndTouch(orb)
                tasksDone.phaseOrb = true
                checkAndHop()
            else
                if isErrorGlove() then
                    errorGlitchOrb(orb)
                    tasksDone.phaseOrb = true
                    checkAndHop()
                else
                    showSwBtn(orb.CFrame, "PhaseOrb", orb)
                end
            end
        end)
    end

    -- SiphonOrb：模式1 傳送 + 偽觸碰
    if SIPHON_ORB_MODE == 1 then
        handleOrb("SiphonOrb", 1, function(orb)
            teleportAndTouch(orb)
            tasksDone.siphonOrb = true
            checkAndHop()
        end)
    end

    -- MATERIALIZEOrb：模式1 傳送 + 偽觸碰
    if MATERIALIZE_ORB_MODE == 1 then
        handleOrb("MATERIALIZEOrb", 1, function(orb)
            teleportAndTouch(orb)
            tasksDone.materializeOrb = true
            checkAndHop()
        end)
    end
end)

local function runMainFlow()
    goToTeleport1()

    -- 等待角色裝備任何 Tool
    print("[OrbScript] 等待裝備 Tool...")
    repeat
        task.wait(0.2)
        Character = LocalPlayer.Character
    until Character and Character:FindFirstChildOfClass("Tool")
    print("[OrbScript] 偵測到 Tool，繼續執行")
    task.wait(0.5)
    handleGloves()
    tasksDone.glove = true
    orbDetectionEnabled = true
    print("[OrbScript] Orb 偵測已啟動")
    task.wait(0.1)
    if not anyOrbPresent() then
        print("[OrbScript] 場上無 Orb，直接跳服")
        tasksDone.jetOrb = true; tasksDone.phaseOrb = true
        tasksDone.siphonOrb = true; tasksDone.materializeOrb = true
        checkAndHop()
    end
end

local function resetFlow()
    print("[OrbScript] 重置流程...")
    switchServerPending  = false
    orbDetectionEnabled  = false
    handledOrbs          = {}
    swFrame.Visible      = false
    pendingOrbCF         = nil
    pendingOrbRef        = nil
    tasksDone = {
        glove          = (GLOVE_TELEPORT == 0),
        jetOrb         = (JET_ORB_MODE == 0),
        phaseOrb       = (PHASE_ORB_MODE == 0),
        siphonOrb      = (SIPHON_ORB_MODE == 0),
        materializeOrb = (MATERIALIZE_ORB_MODE == 0),
    }
    runMainFlow()
end

-- Watchdog：若 10 秒後 switchServerPending 仍為 false（未觸發跳服），重新執行流程
local function startWithWatchdog()
    task.wait(1)
    task.spawn(runMainFlow)

    task.spawn(function()
        task.wait(10)   -- 載入後等待 10 秒
        if not switchServerPending then
            print("[OrbScript] ⚠ 10秒內未跳服，重新開始流程")
            resetFlow()
        else
            print("[OrbScript] ✓ 10秒內已觸發跳服，Watchdog 結束")
        end
    end)
end

startWithWatchdog()

