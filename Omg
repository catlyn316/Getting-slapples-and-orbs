local function getRootPart()
    Character = LocalPlayer.Character
    if Character then RootPart = Character:FindFirstChild("HumanoidRootPart") end
    return RootPart
end
local function teleportTo(cf)
    local r = getRootPart()
    if r then r.CFrame = cf end
end
local function nameCI(a, b) return string.lower(a) == string.lower(b) end

-- 偽觸碰
local function fakeTouch(orb)
    local char = LocalPlayer.Character
    if not char then return end
    local head = char:FindFirstChild("Head")
    if not head then return end
    firetouchinterest(head, orb, 0)
    firetouchinterest(head, orb, 1)
end

-- 傳送 + 偽觸碰（0.5秒後雙重觸發）
local function teleportAndTouch(orb)
    teleportTo(orb.CFrame)
    task.spawn(function()
        task.wait(0.5)
        if orb and orb.Parent then
            teleportTo(orb.CFrame)
            fakeTouch(orb)
        end
    end)
end

-- Error 手套偽攻擊 → 0.5秒後傳送 + 偽觸碰
local function errorGlitchOrb(orb)
    local rs = game:GetService("ReplicatedStorage")
    local errorhit = rs:FindFirstChild("Errorhit")
    if errorhit then
        errorhit:FireServer(orb)
    end
    task.spawn(function()
        task.wait(0.5)
        if orb and orb.Parent then
            teleportTo(orb.CFrame)
            fakeTouch(orb)
        end
    end)
end

-- 檢查是否裝備 Error 手套
local function isErrorGlove()
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if ls then
        local glove = ls:FindFirstChild("Glove")
        if glove and glove.Value == "Error" then return true end
    end
    return false
end

