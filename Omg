        print("[OrbScript] 場上無 Orb，直接跳服")
        tasksDone.jetOrb = true; tasksDone.phaseOrb = true
        tasksDone.siphonOrb = true; tasksDone.materializeOrb = true
        checkAndHop()
    end
end)

