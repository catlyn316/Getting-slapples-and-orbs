-- 依照 SERVER_HOP_MODE 挑選伺服器並跳過去
local function hopServer()
    if switchServerPending then return end
    switchServerPending = true

    local placeId = game.PlaceId
    local success, pages = pcall(function()
        return TeleportService:GetPlayerPlaceInstanceAsync(placeId)
    end)

    -- 嘗試透過 GetPlayerPlaceInstanceAsync 找空服（Roblox 限制下的替代方案）
    -- 實際跳服使用 TeleportToPlaceInstance 或 TeleportAsync
    local function doTeleport(jobId)
        if jobId then
            TeleportService:TeleportToPlaceInstance(placeId, jobId, LocalPlayer)
        else
            TeleportService:Teleport(placeId, LocalPlayer)
        end
    end

    -- 使用 HttpService 取得伺服器列表（需遊戲允許 HTTP）
    local ok, result = pcall(function()
        local url = "https://games.roproxy.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Asc&limit=100"
        local response = HttpService:GetAsync(url)
        return HttpService:JSONDecode(response)
    end)

    if ok and result and result.data then
        local servers = result.data
        local chosen = nil

        if SERVER_HOP_MODE == 1 then
            -- 人數最少（< 4 優先，否則選最少）
            local best = nil
            for _, s in ipairs(servers) do
                if s.playing and s.id ~= game.JobId then
                    if s.playing < 4 then
                        chosen = s
                        break
                    end
                    if not best or s.playing < best.playing then
                        best = s
                    end
                end
            end
            if not chosen then chosen = best end

        elseif SERVER_HOP_MODE == 2 then
            -- 人數 12～14
            for _, s in ipairs(servers) do
                if s.playing and s.id ~= game.JobId then
                    if s.playing >= 12 and s.playing <= 14 then
                        chosen = s
                        break
                    end
                end
            end

        else
            -- 隨機
            local valid = {}
            for _, s in ipairs(servers) do
                if s.id ~= game.JobId then
                    table.insert(valid, s)
                end
            end
            if #valid > 0 then
                chosen = valid[math.random(1, #valid)]
            end
        end

        if chosen then
            doTeleport(chosen.id)
        else
            -- 沒找到符合條件的就隨機跳
            TeleportService:Teleport(placeId, LocalPlayer)
        end
    else
        -- HTTP 失敗則直接隨機跳
        TeleportService:Teleport(placeId, LocalPlayer)
    end
end

