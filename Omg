-- 【變數1】Glove 傳送
-- ──────────────────────────────────────────────
local function handleGloves()
    if GLOVE_TELEPORT ~= 1 then return end

    local arena = workspace:FindFirstChild("Arena")
    if not arena then return end

    for _, island in ipairs(arena:GetChildren()) do
        -- 尋找每個 island 下的 Slapples
        local slapples = island:FindFirstChild("Slapples")
        if slapples then
            for _, child in ipairs(slapples:GetChildren()) do
                local glove = child:FindFirstChild("Glove")
                if glove and glove:IsA("BasePart") then
                    local root = getRootPart()
                    if root then
                        glove.CFrame = root.CFrame
                    end
                end
            end
        end
    end
end

-- ──────────────────────────────────────────────
-- 通用 Orb 偵測函式
-- ──────────────────────────────────────────────

-- 已處理過的 Orb 實例（避免重複觸發）
local handledOrbs = {}

local function findOrbInWorkspace(orbName)
    for _, v in ipairs(workspace:GetDescendants()) do
        if nameMatchCI(v.Name, orbName) and v:IsA("BasePart") then
            return v
        end
    end
    return nil
end

local function handleOrb(orbName, mode, onFound)
    if mode == 0 then return end
    local orb = findOrbInWorkspace(orbName)
    if orb and not handledOrbs[orb] then
        handledOrbs[orb] = true
        onFound(orb)
        -- 當 Orb 消失時重置記憶
        orb.AncestryChanged:Connect(function(_, parent)
            if parent == nil then
                handledOrbs[orb] = nil
                -- 若物質化提示開著且該 Orb 消失則關閉提示
                if orbName == "materializeorb" and materializePromptOpen then
                    hideMaterializePrompt()
                end
            end
        end)
    end
end

