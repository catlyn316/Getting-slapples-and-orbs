-- 取得最新 RootPart（角色重生後更新）
local function getRootPart()
    Character = LocalPlayer.Character
    if Character then
        RootPart = Character:FindFirstChild("HumanoidRootPart")
    end
    return RootPart
end

-- 傳送角色到目標 CFrame
local function teleportTo(cframe)
    local root = getRootPart()
    if root then
        root.CFrame = cframe
    end
end

-- 不區分大小寫搜尋名稱
local function nameMatchCI(name, target)
    return string.lower(name) == string.lower(target)
end

-- 在 workspace 遞迴尋找符合名稱（不分大小寫）的物件
local function findInstanceCI(parent, targetName)
    for _, v in ipairs(parent:GetDescendants()) do
        if nameMatchCI(v.Name, targetName) then
            return v
        end
    end
    return nil
end

-- 在 workspace 頂層子物件尋找
local function findInWorkspaceCI(targetName)
    for _, v in ipairs(workspace:GetChildren()) do
        if nameMatchCI(v.Name, targetName) then
            return v
        end
    end
    return nil
end

