local function joinSmallestServer()
    if switchServerPending then return end
    switchServerPending = true
    print("[OrbScript] 開始跳服（最少人）...")
    local pid = game.PlaceId
    local success, result = pcall(function()
        local response = HttpService:JSONDecode(
            game:HttpGet("https://games.roblox.com/v1/games/" .. pid .. "/servers/Public?sortOrder=Asc&limit=100")
        )
        if response.data and #response.data > 0 then
            table.sort(response.data, function(a, b) return a.playing < b.playing end)
            local valid = {}
            for _, s in ipairs(response.data) do
                if s.id ~= game.JobId then table.insert(valid, s) end
            end
            local targetServer = valid[8] or valid[1]
            if targetServer and targetServer.id then
                TeleportService:TeleportToPlaceInstance(pid, targetServer.id)
            else
                TeleportService:Teleport(pid, LocalPlayer)
            end
        else
            TeleportService:Teleport(pid, LocalPlayer)
        end
    end)
    if not success then TeleportService:Teleport(pid, LocalPlayer) end
end

local function joinMostPlayedServer()
    if switchServerPending then return end
    switchServerPending = true
    local pid = game.PlaceId
    local success, result = pcall(function()
        local response = HttpService:JSONDecode(
            game:HttpGet("https://games.roblox.com/v1/games/" .. pid .. "/servers/Public?sortOrder=Asc&limit=100")
        )
        if response.data and #response.data > 0 then
            local targetPlayers = math.floor(game.Players.MaxPlayers * 3 / 4)
            local valid = {}
            for _, s in ipairs(response.data) do
                if s.id ~= game.JobId then table.insert(valid, s) end
            end
            table.sort(valid, function(a, b)
                return math.abs(a.playing - targetPlayers) < math.abs(b.playing - targetPlayers)
            end)
            local targetServer = valid[1]
            if targetServer and targetServer.id then
                TeleportService:TeleportToPlaceInstance(pid, targetServer.id)
            else
                TeleportService:Teleport(pid, LocalPlayer)
            end
        else
            TeleportService:Teleport(pid, LocalPlayer)
        end
    end)
    if not success then TeleportService:Teleport(pid, LocalPlayer) end
end

local function hopServer()
    if SERVER_HOP_MODE == 1 then joinSmallestServer()
    elseif SERVER_HOP_MODE == 2 then joinMostPlayedServer()
    else
        if switchServerPending then return end
        switchServerPending = true
        TeleportService:Teleport(game.PlaceId, LocalPlayer)
    end
end

