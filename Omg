-- 判斷所有「自動」任務是否完成（不含需玩家手動確認的）
local tasksDone = {
    glove = GLOVE_TELEPORT == 0,       -- 0 = 不需要做 = 已完成
    jetOrb = JET_ORB_MODE == 0 or JET_ORB_MODE == 2,
    phaseOrb = PHASE_ORB_MODE == 0 or PHASE_ORB_MODE == 2,
    siphonOrb = SIPHON_ORB_MODE == 0,
    materializeOrb = MATERIALIZE_ORB_MODE == 0,
}

local function checkAndHop()
    -- 如果有換服按鈕模式開著，不自動跳
    if JET_ORB_MODE == 2 or PHASE_ORB_MODE == 2 then return end

    for _, done in pairs(tasksDone) do
        if not done then return end
    end
    hopServer()
end

-- ──────────────────────────────────────────────
-- 主偵測迴圈
-- ──────────────────────────────────────────────
RunService.Heartbeat:Connect(function()
    -- 【變數2】JetOrb
    if JET_ORB_MODE ~= 0 then
        handleOrb("JetOrb", JET_ORB_MODE, function(orb)
            local cf = orb.CFrame
            if JET_ORB_MODE == 1 then
                teleportTo(cf)
                tasksDone.jetOrb = true
                hopServer()
            elseif JET_ORB_MODE == 2 then
                showSwitchButton(cf)
            end
        end)
    end

    -- 【變數3】PhaseOrb
    if PHASE_ORB_MODE ~= 0 then
        handleOrb("PhaseOrb", PHASE_ORB_MODE, function(orb)
            local cf = orb.CFrame
            if PHASE_ORB_MODE == 1 then
                teleportTo(cf)
                tasksDone.phaseOrb = true
                hopServer()
            elseif PHASE_ORB_MODE == 2 then
                showSwitchButton(cf)
            end
        end)
    end

    -- 【變數4】SiphonOrb
    if SIPHON_ORB_MODE == 1 then
        handleOrb("SiphonOrb", SIPHON_ORB_MODE, function(orb)
            teleportTo(orb.CFrame)
            tasksDone.siphonOrb = true
            checkAndHop()
        end)
    end

    -- 【變數5】MATERIALIZEOrb（不分大小寫）
    if MATERIALIZE_ORB_MODE == 1 then
        handleOrb("MATERIALIZEOrb", MATERIALIZE_ORB_MODE, function(orb)
            local cf = orb.CFrame
            -- 若變數2或3為2，改為提示框
            if JET_ORB_MODE == 2 or PHASE_ORB_MODE == 2 then
                if not materializePromptOpen then
                    showMaterializePrompt(cf)
                end
            else
                teleportTo(cf)
                tasksDone.materializeOrb = true
                checkAndHop()
            end
        end)
    end
end)

