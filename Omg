local Character       = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local RootPart        = Character:WaitForChild("HumanoidRootPart")

local switchServerPending = false
local orbDetectionEnabled = false

local visitedServers = {}
local VISIT_COOLDOWN = 120

local function markVisited(jobId)
    visitedServers[jobId] = tick()
end
local function isRecentlyVisited(jobId)
    local t = visitedServers[jobId]
    if t and (tick() - t) < VISIT_COOLDOWN then return true end
    return false
end
local function cleanVisited()
    local now = tick()
    for id, t in pairs(visitedServers) do
        if now - t >= VISIT_COOLDOWN then visitedServers[id] = nil end
    end
end
markVisited(game.JobId)

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name           = "OrbHUD"
ScreenGui.ResetOnSpawn   = false
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
