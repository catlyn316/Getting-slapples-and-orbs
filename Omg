-- Orb 偵測工具
local handledOrbs = {}
local function findOrb(name)
    for _, v in ipairs(workspace:GetDescendants()) do
        if nameCI(v.Name, name) and v:IsA("BasePart") then return v end
    end
    return nil
end

-- 場上是否還有任何啟用中的 Orb
local function anyOrbPresent()
    if JET_ORB_MODE == 1 and findOrb("JetOrb") then return true end
    if PHASE_ORB_MODE == 1 and findOrb("PhaseOrb") then return true end
    if SIPHON_ORB_MODE == 1 and findOrb("SiphonOrb") then return true end
    if MATERIALIZE_ORB_MODE == 1 and findOrb("MATERIALIZEOrb") then return true end
    return false
end

-- 雙重保險：旗標全完成 + 場上無殘留 Orb 才跳服
local function checkAndHop()
    if JET_ORB_MODE == 2 or PHASE_ORB_MODE == 2 then return end
    -- 1. 所有任務旗標必須完成
    for _, done in pairs(tasksDone) do
        if not done then
            print("[OrbScript] 還有任務未完成，等待中...")
            return
        end
    end
    -- 2. 場上必須無殘留 Orb
    if anyOrbPresent() then
        print("[OrbScript] 場上仍有 Orb，等待中...")
        return
    end
    hopServer()
end

local function handleOrb(orbName, mode, onFound)
    if mode == 0 then return end
    local orb = findOrb(orbName)
    if orb and not handledOrbs[orb] then
        handledOrbs[orb] = true
        onFound(orb)
        orb.AncestryChanged:Connect(function(_, p)
            if p == nil then
                handledOrbs[orb] = nil
                if string.lower(orbName) == "materializeorb" and materializePromptOpen then
                    hideMatPrompt()
                end
                -- Orb 消失後再次嘗試跳服（可能是最後一顆）
                checkAndHop()
            end
        end)
    end
end

